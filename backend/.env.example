# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# LLM provider - LiteLLM format: "provider/model"
# Examples:
#   gemini/gemini-2.0-flash       (get key at aistudio.google.com)
#   gemini/gemini-2.5-pro
#   groq/llama-3.3-70b-versatile  (free tier at console.groq.com)
#   openai/gpt-4o
#   anthropic/claude-sonnet-4-6
#   ollama/llama3
LLM_MODEL=gemini/gemini-2.0-flash

# Provider API keys - set the one that matches your LLM_MODEL provider
GEMINI_API_KEY=your-gemini-api-key-here
# GROQ_API_KEY=your-groq-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Semantic matching
# Optional override. If unset, Lumino will infer a sensible embedding model
# from LLM_MODEL when possible:
#   gemini/* -> gemini/gemini-embedding-001
#   openai/* -> openai/text-embedding-3-small
#   ollama/* -> ollama/nomic-embed-text
# Semantic linking is strict: if embeddings fail, MATCHES edges will not be created.
# EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_TASK_TYPE=SEMANTIC_SIMILARITY
SEMANTIC_MATCH_ENABLED=true
SEMANTIC_MATCH_THRESHOLD=0.72
SEMANTIC_MATCH_PER_TARGET_ENTITY_LIMIT=1

# App
APP_HOST=0.0.0.0
APP_PORT=8000
OUTPUT_DIR=./outputs
